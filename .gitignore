# .gitignore
# Files and folders that Git should NOT track

# Generated PDF output files
output/

# Python cache files (auto-generated, not needed)
__pycache__/
*.pyc
*.pyo

# Mac system files (invisible files macOS creates automatically)
.DS_Store

# Python virtual environment (if we create one later)
venv/
.env

# Personal session memory — local only, not for GitHub
old_friends_folder/

# Chat exports — private, never commit
captains-log/chat-exports/

# Customer data — GDPR/privacy protection, never upload to GitHub
data/*.pdf
data/*.xlsx
data/APRIL 2026/
data/*/

# Loose asset files in root — originals live in templates/assets/
pecat.png
potpis.png
potpis.ai

# Template test/draft files
templates/*.pdf
